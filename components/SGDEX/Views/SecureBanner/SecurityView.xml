<?xml version="1.0" encoding="utf-8" ?>
<component name="SecurityView" extends="Group">
    <interface>
        <field id="unlocked" type="boolean" value="false" alwaysNotify="true" />
    </interface>
    <script type="text/brightscript" uri="pkg:/components/SGDEX/Views/SecureBanner/SecurityView.brs" />
    <children>
        <!-- <Rectangle width="1920" height="1080" color="0x111111FF" /> -->
        <FadingBackground
            id="backgroundImageSecurityView"
            width="1280"
            height="720"
            animationDuration ="0.5"
            uri="pkg:/images/webp/background_hd.webp"
        />
        
        <LayoutGroup
            translation="[640, 360]"
            horizAlignment="center"
            vertAlignment="center"
            itemSpacings="[10]"
            >
            
            
            <Label id="instructionLabel" text="Ingrese el código de seguridad:" translation="[0, 200]" width="1920" horizAlign="center" font="font:LargeBoldSystemFont" color="0xFFFFFFFF" />
            <Label id="pinLabel" text="" translation="[0, 300]" width="1920" horizAlign="center" font="font:LargeBoldSystemFont" color="0x00FF00FF" />
            <!-- Change color in MarkupGrid -->
            <MarkupGrid id="numberGrid" 
                   translation="[420, 320]"
                   itemComponentName="NumberPadItem" 
                   itemSize="[120, 120]" 
                   itemSpacing="[10, 10]" 
                   numColumns="4" 
                   color="0x000000FF"
                   
                   drawFocusFeedback="true" />
            <Label id="getCodeLabel" text="O escanee el código QR" translation="[0, 200]" width="1920" horizAlign="center" font="font:LargeBoldSystemFont" color="0xFFFFFFFF" />
            
            <StyledPoster
                id="qrCodePoster"
                maxWidth="357"
                maxHeight="201"
                uri="pkg:/images/qrme.png"
            />
        </LayoutGroup>
    </children>
</component>    
